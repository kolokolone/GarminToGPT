{
  "name": "garmin-to-gpt-workspace",
  "private": true,
  "version": "0.3.0",
  "scripts": {
    "backend:dev": "uv run uvicorn app.main:app --app-dir backend --host 127.0.0.1 --port 8000 --reload",
    "backend:test": "uv run pytest",
    "backend:lint": "uv run ruff check backend",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:test": "npm --prefix frontend test",
    "frontend:typecheck": "npm --prefix frontend run typecheck",
    "test": "npm run backend:test && npm run frontend:test"
  }
}
